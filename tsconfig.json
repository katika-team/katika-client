{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "lib": [
      "ES2021",
      "DOM"
    ],
    "allowJs": false,
    "jsx": "react-native",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/lib/*": [
        "lib/*"
      ],
      "@/services/*": [
        "services/*"
      ],
      "@/store/*": [
        "store/*"
      ],
      "@/hooks/*": [
        "hooks/*"
      ],
      "@/components/*": [
        "components/*"
      ],
      "@/assets/*": [
        "assets/*"
      ],
      "@/constant/*": [
        "constant/*"
      ]
    },
    "types": [
      "expo",
      "react",
      "react-native",
      "expo-router/types"
    ],
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true
  },
  "extends": "expo/tsconfig.base",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "node_modules/expo-auth-session/**"
  ]
}
